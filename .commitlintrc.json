{
    "extends": ["@commitlint/config-conventional"],
    "rules": {
        "type-enum": [
            2,
            "always",
            [
                "feat",
                "fix",
                "docs",
                "style",
                "refactor",
                "perf",
                "test",
                "chore",
                "ci",
                "revert"
            ]
        ],
        "subject-case": [
            2,
            "never",
            ["start-case", "pascal-case", "upper-case"]
        ],
        "body-leading-blank": [2, "always"],
        "footer-leading-blank": [2, "always"]
    }
}
