{
    "git": {
        "commitMessage": "chore(release): v${version}",
        "tagName": "v${version}",
        "requireBranch": "main",
        "requireCommits": true,
        "tagAnnotation": "Release v${version}"
    },
    "github": {
        "release": true,
        "releaseName": "Release v${version}",
        "preRelease": false
    },
    "npm": {
        "publish": false
    },
    "plugins": {
        "@release-it/conventional-changelog": {
            "preset": "angular",
            "infile": "CHANGELOG.md"
        }
    },
    "hooks": {
        "before:release": "echo 'Version: ${version}' && echo '${version}' > .version"
    }
}
